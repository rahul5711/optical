<style>
   
    html body {
        zoom: 100%;
        font-family: 'Calibri', sans-serif;
        padding: 0;
        
        height: auto;
        width: 99%;
           padding-bottom: 50px !important;
    }

     .headingName {
         position: absolute;
         margin-left: 36%;
         width: 20%;
         margin-top: 0px;
         font-size: 16px !important;
         text-align: center;
         font-weight: 600 !important;
         padding: 2px 10px;
         border-radius: 5px;vertical-align: middle;
      }

  .powerTbl {
        border: 1px solid #000;
        width: 100%;
    
        border-collapse: collapse;
    }

    .powerTbl td,
    .powerTbl th {
         border: 1px solid #000;
        text-align: center;
       padding: 0;
  
    }
    .powerTbl tr {
         height: 25px;
  
    }

      .productlist table tbody tr td {
    border: 1px solid #000;
    border-bottom: none !important;
    border-top: none !important;
  }
      .productlist table tbody tr td:nth-child(odd) {

    border: none !important;
  }
      .productlist table thead tr th:nth-child(odd) {

    border-left: none !important;
    border-right: none !important;
  }
 .productlist table thead tr th{
    border: 1px solid #000;
      border-top: none !important;
  }

   .productlist table{
    border-collapse: collapse;
     border: 1px solid #fff;
   }
   .billTotalRow {
    border-collapse: collapse;
    
   }

    .billTotalRow  tr td ,  .billTotalRow tr th{
    border: 1px solid #000;
    padding: 2px 4px;
  }

   
  
     
</style>

<body >
   <section style="width: 100%; height: auto; border: 1px solid #000; ">
    <!-- header section start -->
    <section style="width: 100%; height: auto; ">
        <%- include('./header.ejs', {pageNumber: 1}) %>
    </section>

    <!-- heading Bill line  start-->
