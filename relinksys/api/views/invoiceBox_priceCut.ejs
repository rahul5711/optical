                                                                        <%}%>
                                            </tr>
                                            <%})}%>
                                                <!-- serviceList end -->
                        </tbody>
                </table>
            </section>

            <section style=" margin-top: 1%; width: 100%; height: 200px; ">
                <div style=" margin-top: 1%; width: 100%; height: 120px;">

                
                <table style="width: 65%; float: left; height: auto;">
                     <tr>
        <td>
             <h4 <% %> style="color: <%= data.Color %>;padding: 0; margin:0;"> Important Note</h4>
                <% if(data.welComeNoteShop.length !==0){ data.welComeNoteShop.forEach(function (i, index) { %>
                            <p <% %> style="font-size:<%= data.NoteFont %> ; line-height:<%= data.NoteLineSpace %>;
                                        padding: 0; margin:0;">
                                        <%=index+1%>. <%=i.Content%>
                            </p>
                            <%})}%>
        </td>
    </tr>
                <tr  >           
                    <th  style="padding: 2px; border-radius: 5px; text-align: left; "> 
                       <%= data.shopdetails.ShopTiming %>
                    </th>
                </tr>
                </table>
                <table class="billTotalRow" style="width: 30%;float: right;height: auto; ">
                     <% if ( data.bill==='Tax Invoice' ){%>
                         <tr style="height: 20px !important; font-size: 20px ;">
                                    <td >Paid Amount</td>
                                    <td style="text-align: right">  <%= data.recivePayment.toFixed(2) %></td>
                                </tr>
                                <tr style="height: 40px !important; font-size: 20px ;">
                                    <td>Due Amount</td>
                                    <td style="text-align: right">   <%= data.CurrentInvoiceBalance %></td>
                                </tr>
                               
                                <tr>
                                    <td colspan="2" 
                                    <% %>  style="text-align: center;font-size:<%= data.CustomerFont %> ; line-height:<%= data.CustomerLineSpace %>;  padding: 2px 4px; margin:0px "> You've Saved <%=data.SavedDiscount + data.totalPirecCut%> <% if (data.companysetting.CompanyID == 19 ){%> AED <%}%> <% if (data.shopdetails.CompanyID != 19 ){%> Rs <%}%> on this Invoice!
                                </td>
                                </tr>
                            <%}%>

                            <% if ( data.bill !== 'Tax Invoice' ){%>
                                  <tr style="height: 20px !important; font-size: 20px ;">
                                    <td style="text-align: left">Total</td>
                                    <td style="text-align: right">  <%= data.subtotals %></td>
                                </tr>
                                <% if (data.shopdetails.Discounts==="true" && data.billMaster.DiscountAmount != 0){%>
                                <tr style="height: 20px !important; font-size: 20px ;">
                                    <td style="text-align: left">Discount</td>
                                    <td style="text-align: right">  <%= data.billMaster.DiscountAmount %></td>
                                </tr>
                                <%}%>
                                <% if (data.shopdetails.AdminDiscount==="true" && data.billMaster.AddlDiscount != 0){%>
                                <tr style="height: 20px !important; font-size: 20px ;">
                                    <td style="text-align: left">A Discount</td>
                                    <td style="text-align: right">  <%= data.billMaster.AddlDiscount %></td>
                                </tr>
                                <%}%>
                                <tr style="height: 20px !important; font-size: 20px ;">
                                    <td style="text-align: left"> Grand Total</td>
                                    <td style="text-align: right">  <%= data.billMaster.TotalAmount %></td>
                                </tr>
                                <tr style="height: 20px !important; font-size: 20px ;">
                                    <td style="text-align: left"> Advance</td>
                                    <td style="text-align: right">  <%= data.recivePayment.toFixed(2) %></td>
                                </tr>
                                <tr style="height: 20px !important; font-size: 20px ;">
                                    <td style="text-align: left">Balance</td>
                                    <td style="text-align: right">  <%= data.CurrentInvoiceBalance %></td>
                                </tr>
                                <tr>
                                    <td colspan="2"
                                    <% %>  style="text-align: center;font-size:<%= data.CustomerFont %> ; line-height:<%= data.CustomerLineSpace %>; padding: 2px 4px; margin:0px "> You've Saved <%=data.SavedDiscount + data.totalPirecCut%> <% if (data.companysetting.CompanyCurrency == "INR" ){%> Rs. <%}%> <% if (data.companysetting.CompanyCurrency != "INR"){%> <%= data.companysetting.CompanyCurrency %> <%}%> on this Invoice!
                                </td>
                                </tr>
                                    <%}%>
                </table>
                </div>
            </section>
            </section>
</body>

</html>