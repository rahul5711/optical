        </div>
    </section>
    <!-- heading Bill line  end-->

    <section style="width: 100%; height: auto;">
        <table style="width: 100%;">
    <tr>
        <td style="width: 40%; vertical-align: top !important; white-space: nowrap;  ">
            <table  <% %> style="width: 100%;font-size:<%= data.CustomerFont %> ;  line-height: <%= data.CustomerLineSpace %>;">
                <tr><td style="width: 25%;">Invoice No.</td><td>: <%=data.billMaster.InvoiceNo%></td></tr>
                <tr><td style="width: 25%;">Name</td><td>: <%=data.customer.Title%> <%=data.customer.Name%></td></tr>
                <tr><td style="width: 25%;">Mobile No.</td><td>: <%=data.customer.MobileNo1%></td></tr>
                  <% if (data.customer.GSTNo != '' && data.bill==='Tax Invoice'){%>
                   <tr><td style="width: 25%;">GST No.</td><td>: <%=data.customer.GSTNo%></td></tr>
                 <%}%>
            </table>
        </td>
        <td style="width: 20%;"></td>
        <td style="width: 40%; vertical-align: top !important; ">
            <table <% %> style="width: 100%;font-size:<%= data.CustomerFont %> ; line-height: <%= data.CustomerLineSpace %>;">
                <tr><td style="width: 40%;">Bill Date</td><td>: <%=data.billMaster.BillDate%></td></tr>
                <tr><td style="width: 40%;">Del Date</td><td>: <%=data.billMaster.DeliveryDate%></td></tr>
                <tr><td style="width: 40%; vertical-align: top !important; ">Sale Person</td><td style="vertical-align: top !important;">: <%=data.employee%> </td></tr>
            </table>
        </td>
    </tr>
</table>
</section>

