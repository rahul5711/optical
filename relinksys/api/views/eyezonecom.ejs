                                                            <% } else { %>
                                                                <%= new Intl.NumberFormat(data.currencyLocale, { 
                                                                    style: 'currency', 
                                                                    currency: data.currencyFormat
                                                                }).format(i.GSTAmount) %>
                                                            <% } %>
                                                        <% } else { %>
                                                            <%= i.GSTAmount %>
                                                        <% } %>
                                                             <br> @ <%= i.GSTPercentage %>
                                                        </td>
                                                        <%} else { %>
                                                            <td>
                                                                <% if (data.currencyFormat) { %>
                                                            <% if (data.currencyFormat === 'AED') { %>
                                                                <span style="display: inline-flex; align-items: center; gap: 4px;">
                                                                    <img src="http://localhost:3000/assest/UAE_Dirham_Symbol.png" alt="AED Icon" class="AEDIcon" />
                                                                    <%= i.GSTAmount %> <!-- Only number -->
                                                                </span>
                                                            <% } else { %>
                                                                <%= new Intl.NumberFormat(data.currencyLocale, { 
                                                                    style: 'currency', 
                                                                    currency: data.currencyFormat
                                                                }).format(i.GSTAmount) %>
                                                            <% } %>
                                                        <% } else { %>
                                                            <%= i.GSTAmount %>
                                                        <% } %>
                                                                 <br> @ <%= i.GSTPercentage %>
                                                            </td>
                                                            <% } %>
                                                                <%}%>

                                                                    <% if
                                                                        (data.shopdetails.Total==="true"
                                                                        ){%>
                                                                        <td style="text-align: end; padding-right: 5px;">
                                                                            

                                                                            <% if (data.currencyFormat) { %>
                                                            <% if (data.currencyFormat === 'AED') { %>
                                                                <span style="display: inline-flex; align-items: center; gap: 4px;">
                                                                    <img src="http://localhost:3000/assest/UAE_Dirham_Symbol.png" alt="AED Icon" class="AEDIcon" />
                                                                    <%= i.TotalAmount %> <!-- Only number -->
                                                                </span>
                                                            <% } else { %>
                                                                <%= new Intl.NumberFormat(data.currencyLocale, { 
                                                                    style: 'currency', 
                                                                    currency: data.currencyFormat
                                                                }).format(i.TotalAmount) %>
                                                            <% } %>
                                                        <% } else { %>
                                                            <%= i.TotalAmount %>
                                                        <% } %>
                                                                        </td>
                                                                        <%}%>
                                            </tr>
                                            <%})}%>
                                                <!-- serviceList end -->
                        </tbody>
                </table>
            </section>

