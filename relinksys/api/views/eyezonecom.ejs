     .headingName {
         position: absolute;
         margin-left: 36%;
         width: 20%;
         color: rgb(255, 255, 255);
         margin-top: 0px;
         font-size: 16px !important;
         background-color: #b30000;
         text-align: center;
         font-weight: 600 !important;
         padding: 2px 10px;
         border-radius: 5px;vertical-align: middle;
      }
  .productlist table tr td , .productlist table tr th{
    border: .5px solid #cdcdcd;
  }

   .powerTbl {
        border: 1px solid #cdcdcd;
        width: 100%;
        border-radius: 5px;
        border-collapse: separate;
    }

    .powerTbl td,
    .powerTbl th {
       
        text-align: center;
       padding: 0;
  
